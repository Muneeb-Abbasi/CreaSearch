{
    "buildCommand": "npm run build",
    "outputDirectory": "dist/public",
    "functions": {
        "api/[...route].ts": {
            "runtime": "@vercel/node@3"
        }
    },
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api/[...route]"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}